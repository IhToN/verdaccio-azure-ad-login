{
  "name": "verdaccio-azure-ad-login",
  "version": "1.4.0",
  "description": "Let your users authenticate into Verdaccio using Azure AD OAuth",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "engines": {
    "node": ">=10"
  },
  "dependencies": {
    "@verdaccio/commons-api": "^9.7.1",
    "axios": "^1.7.9",
    "querystring": "^0.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^26.0.20",
    "@types/node": "^18.19.0",
    "@verdaccio/babel-preset": "^9.7.1",
    "@verdaccio/eslint-config": "^13.1.1",
    "@verdaccio/types": "^9.7.2",
    "eslint": "^10.4.0",
    "jest": "^26.6.3",
    "prettier": "^3.4.0",
    "standard-version": "^9.5.0",
    "typescript": "^4.9.5",
    "verdaccio": "^6.7.1"
  },
  "overrides": {
    "@babel/core": "^7.28.0",
    "@babel/runtime": ">=7.26.10",
    "semver": ">=5.7.2",
    "yaml": ">=2.0.0",
    "hosted-git-info": ">=2.8.9"
  },
  "keywords": [
    "verdaccio,azure,active,directory,oauth,login"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IhToN/verdaccio-azure-ad-login.git"
  },
  "author": "Antonio Terrero Algaba <atalgaba@gmail.com>",
  "scripts": {
    "start": "verdaccio -c ./config/dev.yaml",
    "build": "npm run build:types && npm run build:js",
    "release": "standard-version -a",
    "deploy": "git push --follow-tags origin master && npm publish --registry=https://registry.npmjs.org",
    "build:js": "babel src/ --out-dir lib --extensions \".ts,.tsx\"",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "jest",
    "lint": "eslint \"**/*.{js,ts}\""
  }
}
